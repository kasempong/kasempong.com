{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kasempong-com",
  "compatibility_date": "2026-04-25",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "kv_namespaces": [
    { "binding": "HERMES_KV", "id": "REPLACE_WITH_YOUR_KV_NAMESPACE_ID" }
  ]
}
